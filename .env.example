# Copy this file to .env and fill in local secrets. Do not commit .env.

# LLM provider
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro
OPENAI_PROVIDER=deepseek
OPENAI_REASONING_EFFORT=high
OPENAI_THINKING_TYPE=enabled
OPENAI_EXTRA_BODY_JSON=
OPENAI_DISABLE_THINKING_FOR_TOOLS=false
OPENAI_PROXY_URL=
OPENAI_AUTO_PROXY=true
OPENAI_PROXY_PROBE_HOSTS=127.0.0.1:7890,127.0.0.1:7897,127.0.0.1:1080

# Watermark backend
WATERMARK_API_BASE_URL=http://127.0.0.1:8080
# Optional: point RAG ingest at production docs (e.g. ../backend-java/docs)
WATERMARK_DOCS_PATH=

# Runtime persistence
AGENT_CHECKPOINT_PATH=storage/langgraph-checkpoints.sqlite
AGENT_EVENT_STORE_PATH=storage/learnagent-events.sqlite
EVENT_PAGE_DEFAULT_LIMIT=100
EVENT_PAGE_MAX_LIMIT=500
EVENT_PAGE_LEGACY_MAX=1000

# RAG
RAG_USE_VECTOR=false
RAG_REBUILD_INDEX=false
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RAG_CONTEXT_BUDGET_CHARS=14000
HF_HOME=F:\model

# Memory orchestration
MEMORY_ENABLED=true
MEMORY_THREAD_SUMMARY_MAX_RUNS=5
MEMORY_THREAD_SUMMARY_MAX_CHARS=1200
MEMORY_EPISODIC_RECALL_TOP_K=2
MEMORY_INCLUDE_FAILED_RUNS=false
MEMORY_INCLUDE_CANCELLED_RUNS=false
MEMORY_KEY_OUTPUT_MAX_CHARS=800
MEMORY_CHECKPOINT_COMPACT_ENABLED=true
MEMORY_CHECKPOINT_COMPACT_MESSAGE_THRESHOLD=40
MEMORY_CHECKPOINT_COMPACT_KEEP_RECENT_TURNS=6
MEMORY_CHECKPOINT_COMPACT_SUMMARY_MAX_CHARS=2000

# Structured long-term memory (Phase 1 production)
MEMORY_LONG_TERM_ENABLED=true
MEMORY_LONG_TERM_RECALL_TOP_K=3
MEMORY_LONG_TERM_RECALL_MIN_SCORE=0.2
MEMORY_LONG_TERM_IMPORTANCE_MIN=0.5
MEMORY_LONG_TERM_MAX_ITEMS_PER_USER=200
MEMORY_LONG_TERM_PROTECTED_IMPORTANCE=0.9
MEMORY_LONG_TERM_DEDUP_JACCARD_THRESHOLD=0.25
MEMORY_LONG_TERM_CONFLICT_JACCARD_THRESHOLD=0.3
MEMORY_LONG_TERM_TIME_DECAY_HALF_LIFE_DAYS=14
MEMORY_INJECT_DEDUPE_SYSTEM_PROMPT=true
MEMORY_INJECT_DEDUPE_MEMORY_MESSAGES=true
MEMORY_LONG_TERM_USE_VECTOR=false
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_EMBEDDING_DETERMINISTIC=false
MEMORY_LONG_TERM_VECTOR_WEIGHT=0.35
MEMORY_LONG_TERM_VECTOR_MIN_SCORE=0.55
MEMORY_HYDE_ENABLED=true
MEMORY_HYDE_MODE=rule
MEMORY_LLM_EXTRACT_ENABLED=true
MEMORY_LLM_CONFIRM_THRESHOLD=0.7
MEMORY_EMIT_CHECKPOINT_COMPACTED=true

# Run execution limits
RUN_TIMEOUT_SECONDS=120
MAX_CONCURRENT_RUNS=4
MAX_LLM_INFLIGHT=4

# Observability and safety
LANGFUSE_ENABLED=false
COPILOT_ALLOW_JOB_POST=false
